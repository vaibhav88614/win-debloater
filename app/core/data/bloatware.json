  "version": 3,
  "note": "Curated catalog of removable Windows Store (AppX) packages. 'safe:true' entries are shown in Safe mode (well-known, non-critical, reinstallable). 'safe:false' entries require Advanced mode. 'force_required:true' entries are marked NonRemovable by Windows and need an admin registry unlock before removal.",
  "packages": [

    { "id": "Microsoft.MicrosoftEdge.Stable",  "name": "Microsoft Edge",         "category": "Browser",      "safe": false, "force_required": false, "description": "Microsoft Edge (Chromium). The main Edge browser package.", "removal_note": "Uninstalled via Edge's own setup.exe (Remove-AppxPackage cannot touch it). On Windows 11 24H2+, setup.exe may still refuse with exit 93 ('Uninstall was blocked for this product') unless launched from an approved system process; in that case use Settings > Apps > Installed apps > Microsoft Edge, or apply the EEA region workaround. Removal may be reversed by Windows Update. Edge's system services can be separately controlled in the Services tab." },
    { "id": "Microsoft.MicrosoftEdge",          "name": "Edge (Legacy)",          "category": "Browser",      "safe": false, "force_required": true,  "description": "Legacy EdgeHTML-based Microsoft Edge (Windows 10 only).", "removal_note": "Legacy Edge; only present on older Windows 10." },
    { "id": "Microsoft.MicrosoftEdgeDevToolsClient", "name": "Edge DevTools", "category": "Browser",         "safe": false, "force_required": true,  "description": "Edge Developer Tools client component.", "removal_note": "Marked NonRemovable by Windows. On Windows 11 24H2+ (build 26100+) removal is refused by the OS itself (HRESULT 0x80070032) even after the registry unlock; there is no supported way to remove it. Uninstalling Edge Stable does not require removing this component." },
    { "id": "Microsoft.Edge.GameAssist",        "name": "Edge Game Assist",       "category": "Browser",      "safe": true,  "force_required": false, "description": "Edge in-game overlay feature." },

